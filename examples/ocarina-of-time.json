    "user_script": "// Emerald forest green (low) to Triforce gold (high).\nfor(let n=0;n<128;n++){\n  const t=Math.max(0,Math.min(1,(n-21)/87));\n  const t2=t*t;\n  api.setNote(n,\n    Math.round(t2*220),\n    Math.round(160+t*20),\n    Math.round(80*(1-t2))\n  );\n}",
