    "user_script": "// Midnight blue (low) to moonlit silver-white (high).\nfor(let n=0;n<128;n++){\n  const t=Math.max(0,Math.min(1,(n-21)/87));\n  api.setNote(n,\n    Math.round(20+t*175),\n    Math.round(15+t*200),\n    Math.round(120+t*135)\n  );\n}",
